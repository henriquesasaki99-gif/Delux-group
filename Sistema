<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Delux — Sistema do Vendedor</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Cormorant+Garamond:wght@600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box}body{margin:0;font-family:Nunito,Arial,sans-serif;background:#0d0d0f;color:#f7f7f7}.top{position:sticky;top:0;z-index:5;background:rgba(13,13,15,.94);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,.08);padding:14px 18px;display:flex;justify-content:space-between;align-items:center;gap:10px}.brand{font-family:'Cormorant Garamond',serif;font-size:24px;letter-spacing:.06em}.brand span{color:#e8317a}a{color:inherit}.wrap{max-width:1120px;margin:0 auto;padding:22px}.login{max-width:420px;margin:12vh auto;background:#151519;border:1px solid rgba(255,255,255,.09);border-radius:18px;padding:24px}.login h1,.panel h1{font-family:'Cormorant Garamond',serif;margin:0 0 8px;font-size:32px}.muted{color:#aaa;font-size:13px;line-height:1.5}.field{display:flex;flex-direction:column;gap:6px;margin:12px 0}.field label{font-size:11px;text-transform:uppercase;letter-spacing:.14em;color:#aaa;font-weight:800}.field input,.field textarea,.field select{width:100%;background:#0d0d0f;color:#fff;border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:12px;font:16px Nunito;outline:none}.field textarea{min-height:90px;resize:vertical}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.btn{border:0;border-radius:12px;padding:12px 16px;font-weight:800;cursor:pointer;background:#e8317a;color:#fff}.btn.sec{background:#26262d}.btn.danger{background:#421821;color:#ff9ab9}.btn.ok{background:#1f7a4a}.actions{display:flex;gap:10px;flex-wrap:wrap}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:20px 0}.stat{background:#151519;border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:16px}.stat b{font-size:24px}.toolbar{display:flex;justify-content:space-between;gap:12px;align-items:center;margin:16px 0;flex-wrap:wrap}.products{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px}.card{background:#151519;border:1px solid rgba(255,255,255,.08);border-radius:18px;overflow:hidden}.photo{height:190px;background:#222;display:flex;align-items:center;justify-content:center;color:#777;font-weight:800}.photo img{width:100%;height:100%;object-fit:cover}.body{padding:14px}.row{display:flex;justify-content:space-between;gap:10px;align-items:start}.badge{font-size:11px;padding:4px 8px;border-radius:999px;background:#29352d;color:#88ffb8;font-weight:800}.badge.off{background:#3a2630;color:#ff9ab9}.price{color:#f472a8;font-size:20px;font-weight:900}.notice{position:fixed;left:50%;bottom:18px;transform:translateX(-50%);background:#fff;color:#111;padding:10px 14px;border-radius:999px;font-weight:800;display:none;z-index:20}.modal{position:fixed;inset:0;background:rgba(0,0,0,.72);display:none;align-items:center;justify-content:center;z-index:30;padding:14px}.modal.open{display:flex}.box{width:min(760px,100%);max-height:92vh;overflow:auto;background:#151519;border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:18px}.imgprev{width:100%;max-height:240px;object-fit:cover;border-radius:14px;margin-top:8px;display:none}@media(max-width:720px){.top{align-items:flex-start;flex-direction:column}.wrap{padding:14px}.grid,.stats{grid-template-columns:1fr}.products{grid-template-columns:1fr}.actions .btn{flex:1 1 100%}.toolbar{align-items:stretch}.toolbar .btn{width:100%}.login{margin:6vh auto}.box{padding:14px}.photo{height:220px}}
</style>
</head>
<body>
<header class="top"><div class="brand">DELUX <span>Sistema</span></div><div class="actions"><a class="btn sec" href="../index.html">Voltar ao site</a><button class="btn danger" id="logout" style="display:none">Sair</button></div></header>
<div class="wrap">
<section class="login" id="login"><h1>Área do Vendedor</h1><p class="muted">Entre com a senha do administrador. Todos os produtos salvos aqui ficam no mesmo Firebase/Firestore do site.</p><div class="field"><label>Senha</label><input id="pwd" type="password" autocomplete="new-password" placeholder="Digite a senha"></div><button class="btn" id="enter">Entrar</button><p class="muted" id="err" style="color:#ff8fab;display:none">Senha incorreta.</p></section>
<section class="panel" id="panel" style="display:none"><h1>Produtos publicados no site</h1><p class="muted">Cadastre ou edite pelo celular. Marcando “Publicar no site”, o produto aparece na vitrine pública do Delux em todas as telas.</p><div class="stats"><div class="stat"><span class="muted">Produtos</span><br><b id="stAll">0</b></div><div class="stat"><span class="muted">Publicados</span><br><b id="stPub">0</b></div><div class="stat"><span class="muted">Estoque total</span><br><b id="stStock">0</b></div><div class="stat"><span class="muted">Destaques</span><br><b id="stHigh">0</b></div></div><div class="toolbar"><input id="search" placeholder="Buscar produto..." style="flex:1;background:#151519;color:#fff;border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:12px;font-size:16px"><button class="btn" id="add">+ Novo produto</button></div><div class="products" id="products"></div></section>
</div>
<div class="modal" id="modal"><div class="box"><div class="row"><h1 id="modalTitle">Produto</h1><button class="btn sec" id="close">Fechar</button></div><input type="hidden" id="id"><div class="grid"><div class="field"><label>Nome</label><input id="name"></div><div class="field"><label>Loja</label><select id="store"><option>Delux Makes</option><option>Delux By</option><option>Delux Group</option></select></div><div class="field"><label>Categoria pública</label><input id="publicCategory" placeholder="Ex.: Maquiagem, Roupa, Acessório"></div><div class="field"><label>Categoria interna</label><input id="category"></div><div class="field"><label>Preço</label><input id="price" type="number" step="0.01"></div><div class="field"><label>Estoque</label><input id="stock" type="number" step="1"></div></div><div class="field"><label>Descrição pública</label><textarea id="publicDescription"></textarea></div><div class="grid"><div class="field"><label>Publicar no site?</label><select id="publicVisible"><option value="true">Sim</option><option value="false">Não</option></select></div><div class="field"><label>Destaque?</label><select id="publicHighlight"><option value="false">Não</option><option value="true">Sim</option></select></div></div><div class="field"><label>Foto do produto</label><input id="file" type="file" accept="image/*"><img class="imgprev" id="preview"><input id="image" placeholder="URL da imagem" style="margin-top:8px"></div><div class="actions"><button class="btn ok" id="save">Salvar no banco</button><button class="btn danger" id="del">Excluir</button></div></div></div><div class="notice" id="notice">Salvo</div>
<script type="module">
import {initializeApp} from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
import {getFirestore,doc,getDoc,setDoc,onSnapshot} from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js';
const firebaseConfig={apiKey:'AIzaSyBYLW-be1_aOaHwM4f3nC76ZBmP-9kTCtg',authDomain:'delux-group.firebaseapp.com',projectId:'delux-group',storageBucket:'delux-group.firebasestorage.app',messagingSenderId:'971726312316',appId:'1:971726312316:web:ed515078f8aa4932018af9',measurementId:'G-ED9Q04M7NC'};
const app=initializeApp(firebaseConfig),db=getFirestore(app),ref=doc(db,'site_config','admin'),client='sistema_'+Date.now()+'_'+Math.random().toString(36).slice(2);let data={},products=[],logged=false,editing=null;
const $=id=>document.getElementById(id), esc=s=>String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])), money=n=>(Number(n)||0).toLocaleString('pt-BR',{style:'currency',currency:'BRL'}), b64=s=>btoa(unescape(encodeURIComponent(s)));
async function load(){const snap=await getDoc(ref);data=snap.exists()?snap.data():{};products=Array.isArray(data.erpProductsPublic)?data.erpProductsPublic:[];render();}
async function saveAll(){data.erpProductsPublic=products;data.updatedAt=Date.now();data.updatedBy=client;await setDoc(ref,data,{merge:true});toast('Salvo no banco e publicado para o site');}
function toast(t){$('notice').textContent=t;$('notice').style.display='block';setTimeout(()=>$('notice').style.display='none',1700)}
function render(){if(!logged)return;let q=($('search').value||'').toLowerCase();let list=products.filter(p=>!q||String(p.name||'').toLowerCase().includes(q)||String(p.store||'').toLowerCase().includes(q));$('stAll').textContent=products.length;$('stPub').textContent=products.filter(p=>p.publicVisible!==false).length;$('stStock').textContent=products.reduce((s,p)=>s+Number(p.stock||0),0);$('stHigh').textContent=products.filter(p=>p.publicHighlight).length;$('products').innerHTML=list.map(p=>`<article class="card"><div class="photo">${p.image?`<img src="${esc(p.image)}">`:'Sem foto'}</div><div class="body"><div class="row"><div><b>${esc(p.name||'Produto')}</b><div class="muted">${esc(p.store||'Delux Group')} • ${esc(p.publicCategory||p.category||'Produto')}</div></div><span class="badge ${p.publicVisible===false?'off':''}">${p.publicVisible===false?'Oculto':'Publicado'}</span></div><p class="muted">${esc(p.publicDescription||'')}</p><div class="row"><div class="price">${money(p.price)}</div><button class="btn sec" data-edit="${esc(p.id)}">Editar</button></div></div></article>`).join('')||'<p class="muted">Nenhum produto cadastrado.</p>';document.querySelectorAll('[data-edit]').forEach(btn=>btn.onclick=()=>openForm(products.find(p=>p.id===btn.dataset.edit)));}
function blank(){return{id:'p_'+Date.now(),name:'Novo produto',store:'Delux Makes',category:'Produto',publicCategory:'Produto',publicDescription:'Produto disponível para compra pelo WhatsApp.',price:0,stock:1,publicVisible:true,publicHighlight:false,image:''}}
function openForm(p){editing=p||blank();$('modalTitle').textContent=p?'Editar produto':'Novo produto';['id','name','store','publicCategory','category','price','stock','publicDescription','image'].forEach(k=>$(k).value=editing[k]??'');$('publicVisible').value=String(editing.publicVisible!==false);$('publicHighlight').value=String(!!editing.publicHighlight);$('preview').src=editing.image||'';$('preview').style.display=editing.image?'block':'none';$('modal').classList.add('open');}
function close(){editing=null;$('file').value='';$('modal').classList.remove('open')}
async function upload(file){const fd=new FormData();fd.append('file',file);fd.append('upload_preset','bgxns4k4');const r=await fetch('https://api.cloudinary.com/v1_1/dmwla4uia/image/upload',{method:'POST',body:fd});const j=await r.json();if(!j.secure_url)throw new Error('upload');return j.secure_url;}
$('enter').onclick=async()=>{await load();let pwd=data.pwd||'YWRtaW4xMjM=';if(b64($('pwd').value)!==pwd){$('err').style.display='block';return}logged=true;$('login').style.display='none';$('panel').style.display='block';$('logout').style.display='inline-block';render();};
$('logout').onclick=()=>location.reload();$('add').onclick=()=>openForm(null);$('close').onclick=close;$('search').oninput=render;$('file').onchange=async e=>{let f=e.target.files&&e.target.files[0];if(!f)return;toast('Enviando imagem...');let url=await upload(f);$('image').value=url;$('preview').src=url;$('preview').style.display='block';toast('Imagem enviada');};
$('save').onclick=async()=>{let p=editing||blank();['name','store','publicCategory','category','publicDescription','image'].forEach(k=>p[k]=$(k).value);p.price=Number($('price').value||0);p.stock=Number($('stock').value||0);p.publicVisible=$('publicVisible').value==='true';p.publicHighlight=$('publicHighlight').value==='true';let i=products.findIndex(x=>x.id===p.id);if(i>=0)products[i]=p;else products.push(p);await saveAll();close();render();};
$('del').onclick=async()=>{if(!editing||!confirm('Excluir este produto?'))return;products=products.filter(p=>p.id!==editing.id);await saveAll();close();render();};
onSnapshot(ref,snap=>{if(!snap.exists())return;let d=snap.data();if(d.updatedBy===client)return;data=d;products=Array.isArray(data.erpProductsPublic)?data.erpProductsPublic:[];render();});
load().catch(e=>toast('Erro ao carregar Firebase'));
</script>
</body></html>
